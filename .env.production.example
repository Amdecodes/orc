# .env.production.example
# Copy this to .env (or .env.production) on your VPS and fill in the values

# ─── Database & Redis ─────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_db_password
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Auth (Better Auth) ───────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=https://nationalidformatter.app
NEXT_PUBLIC_APP_URL=https://nationalidformatter.app

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# ─── Clerk (Admin) ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_pub_key
CLERK_SECRET_KEY=your_clerk_secret_key

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
# Generate with: openssl rand -hex 32
BOT_SECRET=your_bot_secret

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ─── Encryption ───────────────────────────────────────────────
# REQUIRED: Ensure this is a 64-character hex string
# Generate with: openssl rand -hex 32
FILE_ENCRYPTION_KEY=your_file_encryption_key

# ─── Worker ───────────────────────────────────────────────────
# Node.js heap limit (MB)
WORKER_HEAP_MB=2048
# Parallel processing capacity (Recommended: 2 for 8GB RAM, 5 for 16GB+)
MAX_CONCURRENT_JOBS=2
