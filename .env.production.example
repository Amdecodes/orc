# =============================================================================
# .env.production.example  –  Production environment variables template
# Copy to .env on your VPS and fill in all values before running deploy.sh
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Use a strong, unique password – avoid special characters that break URLs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=et_id_ocr

DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/et_id_ocr?schema=public"

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nationalidformatter.app
BETTER_AUTH_URL=https://nationalidformatter.app
BASE_URL=https://nationalidformatter.app

# ── Auth Secret ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Add https://nationalidformatter.app to Authorised Redirect URIs in Google Console
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Bot Secret (shared between web and bot services) ─────────────────────────
# Generate with: openssl rand -hex 32
BOT_SECRET=CHANGE_ME_STRONG_SECRET

# ── Bot internal URL (Docker network – do NOT change) ────────────────────────
BOT_INTERNAL_URL=http://bot:5005

# ── Resend (Email / OTP) ─────────────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME

# ── Telegram Bot (if using the Telegram bot service) ─────────────────────────
# TELEGRAM_BOT_TOKEN=CHANGE_ME
